{
  "$schema": "./custom_train_config.schema.json",
  "episodes": 50000,
  "max_steps_per_episode": 1500,
  "gamma": 0.995,
  "learning_rate": 0.0001,
  "weight_decay": 1e-05,
  "batch_size": 256,
  "replay_capacity": 50000,
  "min_replay_size": 2560,
  "train_frequency": 4,
  "target_update_interval": 2000,
  "grad_clip_norm": 5,
  "epsilon_start": 0.7,
  "epsilon_end": 0.01,
  "epsilon_decay_steps": 600000,
  "eval_episodes": 100,
  "moving_avg_window": 100,
  "log_interval": 40,
  "checkpoint_interval": 1000,
  "tensorboard_log_interval": 5,
  "jsonl_flush_interval": 500,
  "run_name": "custom",
  "output_root": "runs",
  "live_plot": false,
  "tensorboard": true,
  "save_csv": false,
  "save_jsonl": true,
  "device": "auto",
  "lightweight_step_info": true,
  "model_type": "tiny",
  "local_patch_size": 9,
  "curriculum": null,
  "random_board": null,
  "parallel": {
    "enabled": false,
    "num_workers": 4,
    "queue_capacity": 8192,
    "weight_sync_interval_steps": 512,
    "actor_loop_sleep_ms": 0,
    "actor_seed_stride": 100000,
    "actor_device": "cpu"
  },
  "reward_weights": {
    "alive": -0.0002,
    "food": 1,
    "bonusFood": 1.5,
    "death": -1.5,
    "timeout": -5,
    "levelUp": 0.2,
    "victory": 10,
    "foodDistanceK": 0
  },
  "env": {
    "difficulty": "normal",
    "mode": "classic",
    "board_size": 7,
    "enable_bonus_food": false,
    "enable_obstacles": false,
    "allow_leveling": false,
    "max_steps_without_food": 49,
    "seed": null
  }
}